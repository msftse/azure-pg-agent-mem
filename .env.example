# Azure PostgreSQL Flexible Server connection string
# Format: postgres://user:password@your-server.postgres.database.azure.com:5432/your-db?sslmode=require
DATABASE_URL="postgres://user:password@your-server.postgres.database.azure.com:5432/agent_memory?sslmode=require"

# User ID for multi-tenant isolation (auto-derived from OS user + hostname if not set)
# AGENT_MEM_USER_ID="your-unique-user-id"

# Worker service port (default: 37778)
# AGENT_MEM_WORKER_PORT=37778

# Log level: DEBUG, INFO, WARN, ERROR
# AGENT_MEM_LOG_LEVEL=INFO

# ── Embedding provider ──────────────────────────────────────────────────
# Provider: 'nomic' (default, local inference, no API key) or 'azure_openai'
# AGENT_MEM_EMBEDDING_PROVIDER=nomic

# Target vector dimensions (must match DB column; default: 768)
# AGENT_MEM_EMBEDDING_DIMENSIONS=768

# Azure OpenAI settings (required when EMBEDDING_PROVIDER=azure_openai)
# AGENT_MEM_AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AGENT_MEM_AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
# AGENT_MEM_AZURE_OPENAI_API_VERSION=2024-06-01
#
# Authentication (choose one):
# Option A: Entra ID / AAD (recommended — no API key needed, uses DefaultAzureCredential)
#   Just omit AGENT_MEM_AZURE_OPENAI_API_KEY and ensure 'az login' or managed identity is configured.
# Option B: API key
# AGENT_MEM_AZURE_OPENAI_API_KEY=your-api-key
